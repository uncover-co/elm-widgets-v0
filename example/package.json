{
  "name": "elm-widgets-v0-example",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "elm-tooling install",
    "start": "run-pty % npm run start:elm % npm run start:http",
    "start:elm": "elm-watch hot",
    "start:http": "serve dist -s",
    "build": "elm-watch make --optimize"
  },
  "devDependencies": {
    "elm-tooling": "^1.15.0",
    "elm-watch": "^1.2.2",
    "run-pty": "^5.0.0",
    "serve": "^14.2.1"
  }
}
